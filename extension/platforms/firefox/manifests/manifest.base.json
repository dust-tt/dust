{
  "manifest_version": 2,
  "name": "Dust",
  "version": "0.0.13",
  "description": "Get more done, faster, with the power of your agents at your fingertips.",
  "icons": {
    "16": "images/dust16.png",
    "32": "images/dust32.png",
    "48": "images/dust48.png",
    "128": "images/dust128.png"
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_title": "Dust ⇧⌘E"
  },
  "commands": {
    "_execute_browser_action": {
      "suggested_key": {
        "default": "Ctrl + Shift + E",
        "mac": "Command + Shift + E"
      }
    }
  },
  "sidebar_action": {
    "default_title": "Dust",
    "default_panel": "main.html"
  },
  "permissions": [
    "identity",
    "storage",
    "tabs",
    "activeTab",
    "contextMenus",
    "<all_urls>"
  ],
  "externally_connectable": {
    "matches": [
      "https://dust.tt/*",
      "https://alan.com/sales-tools/*",
      "https://alanhealth.lightning.force.com/*"
    ]
  }
}