# /share routes
/share /_share/ 200
/share/* /_share/ 200
# OAuth routes
/oauth/*  /_oauth/  200
/w/:wId/oauth/*  /_oauth/ 200
# Email routes
/email/* /_email/ 200

# SPA fallback is handled by 404.html (copied from index.html at build time).
# This avoids the catch-all /* rewrite which intermittently intercepts static
# asset requests (/assets/*.js) on some Cloudflare edge nodes, returning HTML
# instead of JS and breaking dynamic imports.
