{
  "name": "dust-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "front",
    "front-spa",
    "sparkle",
    "connectors",
    "cli",
    "extension",
    "viz",
    "sdks/js"
  ],
  "scripts": {
    "clean": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "install:all": "npm install",
    "knip": "knip",
    "format": "biome check --write --error-on-warnings .",
    "format:check": "biome check --error-on-warnings .",
    "format:lefthook": "biome format --write",
    "lint": "biome lint --error-on-warnings .",
    "lint:fix": "biome lint --fix --error-on-warnings .",
    "lint:lefthook": "biome lint --error-on-warnings",
    "biome": "biome check --error-on-warnings .",
    "biome:lefthook": "biome check --write --error-on-warnings",
    "test:grit": "grit patterns test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@getgrit/cli": "^0.1.0-alpha.1743007075",
    "knip": "^5.80.0",
    "@typescript/native-preview": "^7.0.0-dev.20260224.1",
    "lefthook": "^2.1.0",
    "wrangler": "^4.67.0"
  },
  "engines": {
    "node": "22.22.0"
  },
  "optionalDependencies": {
    "@biomejs/cli-linux-x64": "2.4.0",
    "@rollup/rollup-linux-x64-gnu": "4.55.2",
    "@swc/core-linux-x64-gnu": "1.15.10"
  },
  "overrides": {
    "eslint-plugin-react-hooks": {
      "zod-validation-error": "^4.0.0"
    },
    "@types/react": "^18.3.18",
    "@modelcontextprotocol/sdk": "^1.27.0"
  }
}
