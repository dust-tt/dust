st res = await throttleWithRedis(\n      RATE_LIMITS[\"chat.appendStream\"],\n      `${this.connectorId}-chat-appendStream`,\n      { canBeIgnored: false },\n      () => this.streamer.append(payload),\n      {}\n    );\n    if (!this.messageTs && res?.ts) {\n      this.messageTs = res.ts;\n    }\n  }\n\n  /**\n   * Show a task card with the default single-task id (for non-run_agent tools).\n   */\n  async startTask(title: string) {\n    await this.updateTask(DEFAULT_TASK_ID, title, \"in_progress\");\n  }\n\n  /**\n   * Create or update a task card by id.\n   * Terminal statuses (complete, error) remove the task from the active set.\n   */\n  async updateTask(taskId: string, title: string, status: TaskStatus) {\n    if (status === \"in_progress\" || status === \"pending\") {\n      this.activeTasks.add(taskId);\n    } else {\n      this.activeTasks.delete(taskId);\n    }\n    await this.append({\n      chunks: [{ type: \"task_update\", id: taskId, title, status }],\n    });\n  }\n\n  async appendText(text: string) {\n    // Complete all active tasks before streaming text.\n    if (this.activeTasks.size > 0) {\n      const chunks = [...this.activeTasks].map((taskId) => ({\n        type: \"task_update\" as const,\n        id: taskId,\n        title: \"Done\",\n        status: \"complete\" as const,\n      }));\n      this.activeTasks.clear();\n      await this.append({ chunks });\n    }\n    await this.append({ markdown_text: text });\n  }\n\n  async stop() {\n    this.activeTasks.clear();\n    this.stopped = true;\n    const res = await this.streamer.stop();\n    if (!this.messageTs && res?.ts) {\n      this.messageTs = res.ts;\n    }\n  }\n}\n",
