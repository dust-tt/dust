{
  "name": "webhook-router",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.22.0"
  },
  "description": "Webhook router for multi-region deployment.",
  "type": "module",
  "main": "dist/firebase.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "npm run build && firebase emulators:start --only functions,storage,database",
    "dev": "npm run start",
    "deploy": "./deploy.sh"
  },
  "author": "Dust",
  "license": "ISC",
  "dependencies": {
    "@biomejs/biome": "^2.4.12",
    "@google-cloud/secret-manager": "^6.0.0",
    "@google-cloud/storage": "^7.17.3",
    "express": "^5.1.0",
    "firebase-admin": "^13.5.0",
    "firebase-functions": "^6.3.2",
    "jose": "^5.0.0",
    "raw-body": "^3.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "22.19.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
